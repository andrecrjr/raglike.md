# --- Server Configuration ---
PORT=4321
HOST=0.0.0.0
ENABLE_API=true
ENABLE_MCP=true

# --- Security ---
# Bearer token for API/MCP authentication
API_TOKEN=your_secure_token_here
# Secret for GitHub/GitLab webhooks
WEBHOOK_SECRET=your_webhook_secret_here

# --- External Embedding API (Optional) ---
# If set, offloads embeddings to this URL instead of running locally
# API_EMBEDDING_URL=https://api.example.com/v1/embeddings
# API_EMBEDDING_TOKEN=your_api_token_here

# --- Database Configuration (Optional) ---
# If unset, uses local PGlite in ./.db/
# POSTGRES_URL=postgres://user:password@localhost:5432/dbname

# --- Logging ---
PINO_LOG_LEVEL=info
