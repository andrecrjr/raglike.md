# --- Server Configuration ---
PORT=4321
HOST=0.0.0.0
ENABLE_API=true
ENABLE_MCP=true

# --- AI Models ---
# The local embedding model used for semantic search (Transformers.js / ONNX)
# Default: Xenova/all-mpnet-base-v2
# Recommended 2026: Xenova/jina-embeddings-v2-base-en
EMBEDDING_MODEL=Xenova/jina-embeddings-v2-base-en

# --- Security ---
# Bearer token for API/MCP authentication
API_TOKEN=your_secure_token_here
# Secret for GitHub/GitLab webhooks
WEBHOOK_SECRET=your_webhook_secret_here

# --- External Embedding API (Optional) ---
# If set, offloads embeddings to this URL instead of running locally
# API_EMBEDDING_URL=https://api.example.com/v1/embeddings
# API_EMBEDDING_TOKEN=your_api_token_here

# --- Database Configuration (Optional) ---
# If unset, the server defaults to a local PGlite database in ./.db/ (or the db service in docker-compose)
# To connect to an outside/external Postgres database (requires pgvector), uncomment and configure:
# POSTGRES_URL=postgres://user:password@your-external-db-host:5432/dbname

# --- Logging ---
PINO_LOG_LEVEL=info
